#!/usr/bin/env bash
set -euo pipefail

readonly LICENSE_API_URL='https://gitlab.com/api/v4/templates/licenses'
DRY_RUN=false
FORCE=false
LICENSE_KEY=

usage() {
  cat <<'EOF'
Usage:
  gh license [--dry-run|-d] [--force|-f] [LICENSE_KEY]

Arguments:
  LICENSE_KEY  License key to use directly instead of selecting with fzf

Examples:
  gh license
  gh license --dry-run MIT
  gh license --force MIT
  gh license MIT
EOF
}

die() {
  printf 'gh-license: %s\n' "$*" >&2
  exit 1
}

need_command() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

ensure_can_write_license() {
  if [[ -e LICENSE && "$FORCE" != true && "$DRY_RUN" != true ]]; then
    die "LICENSE already exists; use --force to overwrite"
  fi
}

fetch_licenses() {
  curl -fsSL "${LICENSE_API_URL}?per_page=100" \
    | jq -r '.[] | [.key, .key, .name] | @tsv'
}

normalize_args() {
  local arg parsing_options

  parsing_options=true

  for arg in "$@"; do
    if [[ "$parsing_options" == true ]]; then
      case "$arg" in
        -h|--help)
          return 2
          ;;
        -d|--dry-run)
          DRY_RUN=true
          continue
          ;;
        -f|--force)
          FORCE=true
          continue
          ;;
        --)
          parsing_options=false
          continue
          ;;
        --*)
          die "unknown option: $arg"
          ;;
      esac
    fi

    [[ -z "$LICENSE_KEY" ]] || die "too many arguments: $arg"
    LICENSE_KEY="$arg"
  done
}

select_license() {
  local licenses selected

  need_command fzf
  need_command awk

  licenses="$(fetch_licenses)"
  if ! selected="$(
    printf '%s\n' "$licenses" \
      | awk -F '\t' '
          {
            spdx_id[NR] = $1
            key[NR] = $2
            name[NR] = $3

            if (length($1) > max) {
              max = length($1)
            }
          }

          END {
            for (i = 1; i <= NR; i++) {
              printf "%s\t%s\t%s\t%-*s  \033[2;37m%s\033[0m\n", spdx_id[i], key[i], name[i], max, spdx_id[i], name[i]
            }
          }
        ' \
      | fzf \
          --ansi \
          --prompt='License> ' \
          --height=40% \
          --layout=reverse \
          --border \
          --delimiter=$'\t' \
          --with-nth=4
  )"; then
    die "no license selected"
  fi

  [[ -n "$selected" ]] || die "no license selected"
  printf '%s\n' "$selected" | cut -f1-3
}

write_license() {
  local license_line spdx_id key name fullname body response

  license_line="$1"
  IFS=$'\t' read -r spdx_id key name <<< "$license_line"

  ensure_can_write_license

  fullname="$(gh api user --jq '.name // .login')" || die "failed to get GitHub user"

  if [[ -z "$fullname" || "$fullname" == "null" ]]; then
    fullname="$(gh api user --jq '.login')" || die "failed to get GitHub user"
  fi

  if ! response="$(
    curl -fsSL --get "${LICENSE_API_URL}/$key" \
      --data-urlencode "fullname=$fullname"
  )"; then
    die "failed to fetch license template: $key"
  fi

  spdx_id="$(printf '%s\n' "$response" | jq -er .key)" || die "failed to parse license template: $key"
  name="$(printf '%s\n' "$response" | jq -er .name)" || die "failed to parse license template: $key"
  body="$(printf '%s\n' "$response" | jq -er .content)" || die "failed to parse license template: $key"

  if [[ "$DRY_RUN" == true ]]; then
    printf '%s\n' "$body"
    return 0
  fi

  printf '%s\n' "$body" > LICENSE
  printf 'Wrote LICENSE using %s (%s) for %s.\n' "$spdx_id" "$name" "$fullname"
}

main() {
  local license_line

  need_command gh
  need_command curl
  need_command jq

  normalize_args "$@" || {
    if [[ "$?" -eq 2 ]]; then
      usage
      exit 0
    fi

    exit 1
  }
  ensure_can_write_license
  if [[ -n "$LICENSE_KEY" ]]; then
    LICENSE_KEY="$(printf '%s' "$LICENSE_KEY" | tr '[:upper:]' '[:lower:]')"
    license_line="$(printf '%s\t%s\t%s\n' "$LICENSE_KEY" "$LICENSE_KEY" "$LICENSE_KEY")"
  else
    license_line="$(select_license)"
  fi
  write_license "$license_line"
}

main "$@"
