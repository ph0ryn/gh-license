#!/usr/bin/env bash
set -euo pipefail

readonly LICENSE_API_URL='https://gitlab.com/api/v4/templates/licenses'
DRY_RUN=false
FORCE=false
LICENSE_KEY=
OUTPUT_FILE=LICENSE

usage() {
  cat <<'EOF'
Usage:
  gh license [--dry-run|-d] [LICENSE_KEY]
  gh license [--force|-f] [--output|-o NAME] [LICENSE_KEY]

Arguments:
  LICENSE_KEY  License key to use directly instead of selecting with fzf

Examples:
  gh license
  gh license --dry-run MIT
  gh license --force MIT
  gh license --output COPYING MIT
  gh license MIT
EOF
}

die() {
  printf 'gh-license: %s\n' "$*" >&2
  exit 1
}

enable_dry_run() {
  [[ "$FORCE" != true ]] || die "--dry-run cannot be used with --force"
  [[ "$OUTPUT_FILE" == LICENSE ]] || die "--dry-run cannot be used with --output"

  DRY_RUN=true
}

need_command() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

ensure_can_write_license() {
  if [[ -e "$OUTPUT_FILE" && "$FORCE" != true && "$DRY_RUN" != true ]]; then
    die "$OUTPUT_FILE already exists; use --force to overwrite"
  fi
}

set_output_file() {
  local name

  [[ "$DRY_RUN" != true ]] || die "--output cannot be used with --dry-run"

  name="$1"
  [[ -n "$name" ]] || die "output file name cannot be empty"
  [[ "$name" != "." && "$name" != ".." ]] || die "invalid output file name: $name"
  [[ "$name" != */* ]] || die "output file name must be in the current directory: $name"

  OUTPUT_FILE="$name"
}

fetch_licenses() {
  curl -fsSL "${LICENSE_API_URL}?per_page=100" \
    | jq -r '.[] | [.key, .name] | @tsv'
}

normalize_args() {
  local arg parsing_options expecting_output

  parsing_options=true
  expecting_output=false

  for arg in "$@"; do
    if [[ "$expecting_output" == true ]]; then
      set_output_file "$arg"
      expecting_output=false
      continue
    fi

    if [[ "$parsing_options" == true ]]; then
      case "$arg" in
        -h|--help)
          return 2
          ;;
        -d|--dry-run)
          enable_dry_run
          continue
          ;;
        -f|--force)
          [[ "$DRY_RUN" != true ]] || die "--force cannot be used with --dry-run"
          FORCE=true
          continue
          ;;
        -o|--output)
          expecting_output=true
          continue
          ;;
        -o?*)
          set_output_file "${arg#-o}"
          continue
          ;;
        --output=*)
          set_output_file "${arg#*=}"
          continue
          ;;
        --)
          parsing_options=false
          continue
          ;;
        --*)
          die "unknown option: $arg"
          ;;
      esac
    fi

    [[ -z "$LICENSE_KEY" ]] || die "too many arguments: $arg"
    LICENSE_KEY="$arg"
  done

  [[ "$expecting_output" != true ]] || die "missing output file name"
}

select_license() {
  local licenses selected

  need_command fzf
  need_command awk

  licenses="$(fetch_licenses)"
  if ! selected="$(
    printf '%s\n' "$licenses" \
      | awk -F '\t' '
          {
            key[NR] = $1
            name[NR] = $2

            if (length($1) > max) {
              max = length($1)
            }
          }

          END {
            for (i = 1; i <= NR; i++) {
              printf "%s\t%s\t%-*s  \033[2;37m%s\033[0m\n", key[i], name[i], max, key[i], name[i]
            }
          }
        ' \
      | fzf \
          --ansi \
          --prompt='License> ' \
          --height=40% \
          --layout=reverse \
          --border \
          --delimiter=$'\t' \
          --with-nth=3
  )"; then
    die "no license selected"
  fi

  [[ -n "$selected" ]] || die "no license selected"
  printf '%s\n' "$selected" | cut -f1-2
}

write_license() {
  local license_line key name fullname body response response_key

  license_line="$1"
  IFS=$'\t' read -r key name <<< "$license_line"

  ensure_can_write_license

  fullname="$(gh api user --jq '.name // .login')" || die "failed to get GitHub user"

  if [[ -z "$fullname" || "$fullname" == "null" ]]; then
    fullname="$(gh api user --jq '.login')" || die "failed to get GitHub user"
  fi

  if ! response="$(
    curl -fsSL --get "${LICENSE_API_URL}/$key" \
      --data-urlencode "fullname=$fullname"
  )"; then
    die "failed to fetch license template: $key"
  fi

  response_key="$(printf '%s\n' "$response" | jq -er .key)" || die "failed to parse license template: $key"
  name="$(printf '%s\n' "$response" | jq -er .name)" || die "failed to parse license template: $key"
  body="$(printf '%s\n' "$response" | jq -er .content)" || die "failed to parse license template: $key"

  if [[ "$DRY_RUN" == true ]]; then
    printf '%s\n' "$body"
    return 0
  fi

  printf '%s\n' "$body" > "$OUTPUT_FILE"
  printf 'Wrote %s using %s (%s) for %s.\n' "$OUTPUT_FILE" "$response_key" "$name" "$fullname"
}

main() {
  local license_line

  need_command gh
  need_command curl
  need_command jq

  normalize_args "$@" || {
    if [[ "$?" -eq 2 ]]; then
      usage
      exit 0
    fi

    exit 1
  }
  ensure_can_write_license
  if [[ -n "$LICENSE_KEY" ]]; then
    LICENSE_KEY="$(printf '%s' "$LICENSE_KEY" | tr '[:upper:]' '[:lower:]')"
    license_line="$(printf '%s\t%s\n' "$LICENSE_KEY" "$LICENSE_KEY")"
  else
    license_line="$(select_license)"
  fi
  write_license "$license_line"
}

main "$@"
